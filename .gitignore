# Scratch / temporary
tmp/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Internal docs (specs, plans), kept local, not published
/docs/

# Dev-tooling config, not needed to run the coach. Kept local so contributors
# can still lint with the intended deviations, but not shipped in the package.
.markdownlint.json

# Pre-Flight memory file, a per-user-project artifact the coach writes at the
# project root. Appears here only when the coach is run inside its own folder
# during testing; never committed to the coach repo.
PREFLIGHT.md

# Claude Code local config stays local. The skills' cross-surface home is
# reference/skills/ (loads as knowledge on Claude Code and Claude.ai); we ALSO
# ship .claude/skills/ so Claude Code registers /plan, /chart, /secops, /learn
# as native slash commands on clone. gitignore patterns are relative to this
# file, so the nested coach .claude/ needs its own pair next to the root one,
# otherwise a stray pre-flight-coach/.claude/settings.local.json is unignored.
.claude/*
!.claude/skills/
pre-flight-coach/.claude/*
!pre-flight-coach/.claude/skills/
