# Scratch / temporary
tmp/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Internal docs (specs, plans), kept local, not published
/docs/

# Pre-Flight memory file, a per-user-project artifact the coach writes at the
# project root. Appears here only when the coach is run inside its own folder
# during testing; never committed to the coach repo.
PREFLIGHT.md

# Claude Code local config. The cross-surface home for the skills is
# reference/skills/ (loads as knowledge on Claude Code and Claude.ai). We ALSO
# ship .claude/skills/ so Claude Code registers /plan, /batch, /safety, /learn as
# native slash commands out of the box. Everything else in .claude/ stays local.
.claude/*
!.claude/skills/
